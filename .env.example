# ─── American Hairline — Environment Variables ───────────────────────────────
#
# 1. Copy this file:   cp .env.example .env.local
# 2. Fill in your key and preferred model
# 3. Run:              npm install && npm run dev
#
# Get your API key at: https://openrouter.ai/keys

# Required — your OpenRouter API key
OPENROUTER_API_KEY=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

# Optional — which image generation model to use (default: Nano Banana)
#
# Real face edits (identity preserved, ~$0.04/image):
#   GENERATE_MODEL=google/gemini-2.5-flash-image        ← recommended
#   GENERATE_MODEL=google/gemini-3.1-flash-image-preview
#
# Text-to-image (no face upload needed, cheaper for testing):
#   GENERATE_MODEL=bytedance/seedream-3-5-default        ← ~$0.04/image, no identity
#   GENERATE_MODEL=bytedance/seedream-3-0-t2i-default
#
# If GENERATE_MODEL is not set, defaults to google/gemini-2.5-flash-image
GENERATE_MODEL=google/gemini-2.5-flash-image
